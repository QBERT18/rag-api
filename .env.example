# Docker Compose overrides.
# Copy to `.env` next to docker-compose.yml to change defaults.

# Ollama model tags pulled by `ollama-init` on first boot.
# Any tag from https://ollama.com/library works.
# gemma3:1b (~815 MB) suits small/4 GB-RAM servers. For more quality on a
# bigger box use gemma3:4b. Ultra-tiny fallback: qwen2.5:0.5b (~400 MB).
OLLAMA_CHAT_MODEL=gemma3:1b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Public hosting via ngrok (only needed with `--profile tunnel`) ---
# Auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Set to /api so the browser hits the backend through the Caddy proxy.
# Leave unset for local-only runs (defaults to http://localhost:8000).
FRONTEND_API_BASE=/api
